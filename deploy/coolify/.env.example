# Optional server-wide config for the webcake-storefront MCP (remote mode).
# Copy the values you need into Coolify's "Environment Variables" UI.
# DO NOT commit real secrets — this repo is public.
#
# This server is multi-user: clients normally send their OWN credentials per request:
#   x-webcake-jwt: <jwt>            — user's WebCake JWT
#   x-webcake-session-id: <wsid>    — user's storefront session/workspace ID
#   x-webcake-site-id: <site_id>    — target site
# Or they authenticate via the OAuth 2.1 flow (see README.md).

# Port the HTTP server listens on (matches docker-compose `expose`).
PORT=8787

# Target environment — picks the API + app base URLs by name. One of: local | staging | prod
WEBCAKE_ENV=prod

# --- Explicit overrides (only needed to override the WEBCAKE_ENV preset) ----------
# Backend API base URL.
# WEBCAKE_API_URL=

# Builder/storefront app base URL (used to build the OAuth consent redirect to /mcp-storefront).
# WEBCAKE_APP_URL=

# --- Persistence (set by docker-compose.yml automatically in Coolify) ----------
# Postgres connection string — OAuth tokens, clients, codes survive restarts.
# DATABASE_URL=postgres://user:password@postgres:5432/webcake_storefront

# Redis connection string — short-TTL access-token cache (avoids Postgres round-trip per /mcp request).
# REDIS_URL=redis://redis:6379

# --- Optional integrations ----------------------------------------------------
# MongoDB URI for image-alt cache (used by fetch_images_for_alt_fill tool).
# MONGO_URI=

# Pexels API key for image search tools.
# PEXELS_API_KEY=

# --- OAuth TTL overrides (milliseconds) ---------------------------------------
# WEBCAKE_OAUTH_ACCESS_TTL_MS=3600000   # 1 hour (default)
# WEBCAKE_OAUTH_REFRESH_TTL_MS=2592000000  # 30 days (default)

# --- Postgres pool tuning -----------------------------------------------------
# WEBCAKE_PG_POOL_MAX=5
# WEBCAKE_PG_SSL=0   # Set to 1 for managed Postgres (Supabase, Neon, RDS, etc.)
